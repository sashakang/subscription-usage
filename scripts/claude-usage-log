#!/bin/bash
# Claude Usage Logger - appends usage snapshot + rebuilds static dashboard
# Designed to run via launchd every 5 minutes

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG_DIR="$HOME/.claude/projects/claude-usage-dashboard"
mkdir -p "$LOG_DIR"

LOG_FILE="$LOG_DIR/claude-usage.jsonl"

# Deduplication: skip if last record is less than 60s old
if [ -f "$LOG_FILE" ]; then
  LAST_TS=$(tail -1 "$LOG_FILE" 2>/dev/null | python3 -c "
import sys, json
from datetime import datetime, timezone
try:
    r = json.loads(sys.stdin.read())
    ts = datetime.fromisoformat(r['ts'])
    age = (datetime.now(timezone.utc) - ts).total_seconds()
    print(int(age))
except:
    print(999)
" 2>/dev/null) || LAST_TS=999
  if [ "$LAST_TS" -lt 60 ]; then
    exit 0
  fi
fi

# Helper: write error record as proper JSON
log_error() {
  python3 -c "
import json, sys
from datetime import datetime, timezone
print(json.dumps({'error': sys.argv[1], 'ts': datetime.now(timezone.utc).isoformat()}))
" "$1" >> "$LOG_FILE"
}

# Wait for network after sleep/wake (up to 30s)
for i in $(seq 1 6); do
  curl -s --max-time 3 -o /dev/null "https://api.anthropic.com" 2>/dev/null && break
  sleep 5
done

# Get token from Keychain
TOKEN=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
  | python3 -c "import sys,json; print(json.loads(sys.stdin.read())['claudeAiOauth']['accessToken'])" 2>/dev/null) || {
  log_error "keychain_read_failed"
  exit 1
}

# Fetch usage (retry up to 3 times for network errors or null responses)
RAW=""
GOOD=false
for attempt in 1 2 3; do
  if RAW=$(curl -s --max-time 10 "https://api.anthropic.com/api/oauth/usage" \
    -H "Authorization: Bearer $TOKEN" \
    -H "anthropic-beta: oauth-2025-04-20" 2>/dev/null); then
    # Check if response has real data (five_hour field is non-null)
    if echo "$RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if d.get('five_hour',{}).get('utilization') is not None else 1)" 2>/dev/null; then
      GOOD=true
      break
    fi
  fi
  if [ "$attempt" -lt 3 ]; then
    sleep 5
  fi
done

if [ "$GOOD" != "true" ]; then
  log_error "api_failed_after_retries"
  exit 1
fi

# Fetch Claude profile for account identity
CLAUDE_PROFILE=$(curl -s --max-time 5 "https://api.anthropic.com/api/oauth/profile" \
  -H "Authorization: Bearer $TOKEN" \
  -H "anthropic-beta: oauth-2025-04-20" 2>/dev/null) || CLAUDE_PROFILE=""

# Fetch OpenAI Codex usage (best-effort — failure doesn't block Claude logging)
CODEX_RAW=""
CODEX_AUTH="$HOME/.codex/auth.json"
if [ -f "$CODEX_AUTH" ]; then
  CODEX_TOKEN=$(python3 -c "import sys,json; print(json.load(open(sys.argv[1]))['tokens']['access_token'])" "$CODEX_AUTH" 2>/dev/null) || CODEX_TOKEN=""
  if [ -n "$CODEX_TOKEN" ]; then
    for attempt in 1 2 3; do
      if CODEX_RAW=$(curl -s --max-time 10 "https://chatgpt.com/backend-api/wham/usage" \
        -H "Authorization: Bearer $CODEX_TOKEN" 2>/dev/null); then
        if echo "$CODEX_RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if d.get('rate_limit',{}).get('primary_window') else 1)" 2>/dev/null; then
          break
        fi
      fi
      CODEX_RAW=""
      if [ "$attempt" -lt 3 ]; then sleep 3; fi
    done
  fi
fi

# Rotate old records (>7d) before appending — safe because this is the sole writer
# Then append new records. Both operations in one Python call to avoid gaps.
# Pass API responses via env vars (not stdin — heredoc uses stdin for the script source)
export CLAUDE_RAW="$RAW"
export CLAUDE_PROFILE
export CODEX_RAW
python3 - "$LOG_FILE" <<'PYEOF'
import json, sys, os, tempfile
from datetime import datetime, timezone, timedelta

log_file = sys.argv[1]
raw = os.environ.get('CLAUDE_RAW', '')
claude_profile = os.environ.get('CLAUDE_PROFILE', '')
codex_raw = os.environ.get('CODEX_RAW', '')
cutoff = (datetime.now(timezone.utc) - timedelta(days=7)).isoformat()
now = datetime.now(timezone.utc).isoformat()

# Parse Claude account email
claude_account = 'unknown'
try:
    p = json.loads(claude_profile)
    claude_account = p.get('account', {}).get('email', 'unknown')
except:
    pass

# Parse Claude usage
try:
    d = json.loads(raw)
except:
    d = {'error': 'parse_failed', 'raw': raw[:200]}

records = []

# Claude record
records.append({
    'ts': now,
    'service': 'claude',
    'account': claude_account,
    'five_hour': d.get('five_hour', {}).get('utilization'),
    'five_hour_resets': d.get('five_hour', {}).get('resets_at'),
    'seven_day': d.get('seven_day', {}).get('utilization'),
    'seven_day_resets': d.get('seven_day', {}).get('resets_at'),
    'sonnet': d.get('seven_day_sonnet', {}).get('utilization') if d.get('seven_day_sonnet') else None,
    'extra_enabled': d.get('extra_usage', {}).get('is_enabled', False),
    'extra_used': d.get('extra_usage', {}).get('used_credits'),
    'extra_limit': d.get('extra_usage', {}).get('monthly_limit'),
    'extra_pct': d.get('extra_usage', {}).get('utilization'),
})

# Codex record (if available)
if codex_raw:
    try:
        cx = json.loads(codex_raw)
        rl = cx.get('rate_limit', {})
        pw = rl.get('primary_window', {})
        sw = rl.get('secondary_window', {})
        records.append({
            'ts': now,
            'service': 'codex',
            'account': cx.get('email', 'unknown'),
            'five_hour': pw.get('used_percent'),
            'five_hour_resets': datetime.fromtimestamp(pw['reset_at'], tz=timezone.utc).isoformat() if pw.get('reset_at') else None,
            'seven_day': sw.get('used_percent'),
            'seven_day_resets': datetime.fromtimestamp(sw['reset_at'], tz=timezone.utc).isoformat() if sw.get('reset_at') else None,
        })
    except:
        pass

# Read existing, split into keep vs archive
keep = []
archive = []
if os.path.exists(log_file):
    for l in open(log_file).read().strip().split('\n'):
        if not l:
            continue
        try:
            r = json.loads(l)
            if 'error' in r:
                continue
            if r.get('ts', '') >= cutoff:
                keep.append(l)
            else:
                archive.append(l)
        except:
            pass

# Archive old records
if archive:
    archive_file = os.path.join(os.path.dirname(log_file), 'claude-usage-archive.jsonl')
    with open(archive_file, 'a') as f:
        f.write('\n'.join(archive) + '\n')
    print(f'Rotated: archived {len(archive)} old records', file=sys.stderr)

# Write kept records + new records atomically
for rec in records:
    keep.append(json.dumps(rec))
fd, tmp = tempfile.mkstemp(dir=os.path.dirname(log_file), suffix='.tmp')
try:
    with os.fdopen(fd, 'w') as f:
        f.write('\n'.join(keep) + '\n')
    os.rename(tmp, log_file)
except:
    os.unlink(tmp)
    raise
PYEOF

# Rebuild static dashboard
claude-usage-build "$LOG_FILE" 2>&1 || echo "warning: dashboard build failed" >&2
